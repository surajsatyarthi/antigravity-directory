# ============================================
# ANTIGRAVITY DIRECTORY - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env.local for local development
# Never commit .env.local to git

# ============================================
# DATABASE (Supabase PostgreSQL)
# ============================================
DATABASE_URL="postgresql://postgres:[password]@db.[project-id].supabase.co:5432/postgres"

# ============================================
# AUTHENTICATION (NextAuth + Google OAuth)
# ============================================
# Generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET="your-secret-key-here-must-be-at-least-32-chars"
NEXTAUTH_URL="http://localhost:3000" # Required for NextAuth in some environments

# Google OAuth
# Get from Google Cloud Console: https://console.cloud.google.com/
GOOGLE_CLIENT_ID="your-google-oauth-client-id"
GOOGLE_CLIENT_SECRET="your-google-oauth-client-secret"


# GitHub Personal Access Token (for scraper/tools)
GITHUB_TOKEN="your-github-pat"

# ============================================
# AI / CONTENT GENERATION
# ============================================
# Get from Google AI Studio: https://makersuite.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY="your-gemini-api-key"

# ============================================
# EMAIL (Resend)
# ============================================
# Get from Resend: https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"

# ============================================
# REDIS (Upstash - Rate Limiting)
# ============================================
# Get from Upstash Console: https://console.upstash.com/
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# ============================================
# ANALYTICS & MONITORING
# ============================================
# Google Analytics
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# Sentry
SENTRY_DSN="https://xxxxx@sentry.io/xxxxx"
NEXT_PUBLIC_SENTRY_DSN="https://xxxxx@sentry.io/xxxxx"
SENTRY_AUTH_TOKEN="sntry_token_..."

# ============================================
# PUBLIC VARIABLES (Exposed to browser)
# ============================================
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# In production: "https://googleantigravity.directory"

# ============================================
# SEO — IndexNow (Bing/Yandex/Seznam instant indexing)
# ============================================
# Key already obtained. Key file must be in public/{key}.txt
INDEXNOW_KEY="your-indexnow-key"

# ============================================
# ENVIRONMENT
# ============================================
NODE_ENV="development" # or "production"

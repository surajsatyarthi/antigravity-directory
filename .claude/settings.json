{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/inject-rules-after-compact.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/inject-session-rules.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block-src-edits.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/require-screenshots-before-done.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/require-http-status-log.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block-src-edits.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/require-screenshots-before-done.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block-build-commands.sh"
          }
        ]
      }
    ]
  }
}
